# Voidarium — environment template
# Copy to .env and fill in real values. NEVER commit .env.
#
# These are only needed for deploying to Vercel from your machine
# or for the GitHub Actions workflow (set them as repo secrets there:
# Settings → Secrets and variables → Actions).

# Personal token: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Both IDs appear in .vercel/project.json after running `vercel link`
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
